# ============================================================================
# YouTube Data API v3
# ============================================================================
# Get your API key at: https://console.cloud.google.com/apis/credentials
# Enable "YouTube Data API v3" in your project first.
# Free tier: 10,000 units/day (most operations cost 1-3 units).
# Transcript extraction does NOT use this key (it's free via InnerTube).

YOUTUBE_API_KEY=

# ============================================================================
# Local Cache
# ============================================================================
# Path to SQLite database (default: ~/.youtube-skill/youtube.db)
# YOUTUBE_CACHE_DB_PATH=

# ============================================================================
# Client Options
# ============================================================================
# Max retries on 5xx/network errors (default: 3)
# YOUTUBE_MAX_RETRIES=3

# Request timeout in ms (default: 30000)
# YOUTUBE_TIMEOUT=30000

# ============================================================================
# Logging
# ============================================================================
# Log level: debug, info, warn, error (default: info)
LOG_LEVEL=info
